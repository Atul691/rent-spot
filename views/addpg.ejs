<%- include("partials/header") %>

<div class="page-wrap">
  <div class="form-card addpg-card">
    <div class="addpg-head">
      <div>
        <p class="admin-small">Property Management</p>
        <h2>Add New PG</h2>
        <p class="addpg-subtext">Fill details and select multiple images together.</p>
      </div>

      <a href="/admin" class="admin-secondary-btn">Back to Dashboard</a>
    </div>

    <form action="/addpg" method="POST" enctype="multipart/form-data" class="addpg-form">
      <div class="form-grid">
        <div class="form-group">
          <label>PG Name</label>
          <input type="text" name="title" placeholder="Enter PG name" required>
        </div>

        <div class="form-group">
          <label>Price</label>
          <input type="text" name="price" placeholder="Enter price" required>
        </div>

        <div class="form-group">
          <label>Location</label>
          <input type="text" name="location" placeholder="Enter location" required>
        </div>

        <div class="form-group">
          <label>WhatsApp Number</label>
          <input type="text" name="whatsapp" placeholder="Enter WhatsApp number">
        </div>
      </div>

      <div class="form-group full-width">
        <label>Description</label>
        <textarea name="description" placeholder="Write PG description" required></textarea>
      </div>

      <div class="form-group full-width">
        <label>Google Map Link</label>
        <input type="text" name="map" placeholder="Paste normal Google Maps link">
      </div>

      <div class="form-group full-width">
        <label>Upload Multiple PG Images</label>
        <input type="file" name="images" multiple accept="image/*">
        <small class="upload-help">Ctrl daba ke multiple photos select karo.</small>
      </div>

      <div class="form-actions">
        <button type="submit" class="submit-btn">Add PG</button>
        <a href="/admin" class="admin-secondary-btn">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include("partials/footer") %>