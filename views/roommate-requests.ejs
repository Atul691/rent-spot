<%- include("partials/header") %>

<div class="page-wrap">
  <div class="payment-card">
    <h2>My Requests</h2>

    <% if(requests && requests.length > 0){ %>
      <% requests.forEach(function(r){ %>
        <div class="rating-box">
          <h3><%= r.name %></h3>
          <p><%= r.email %></p>

          <p class="status-badge <%= r.status %>">
            <%= r.status ? r.status.toUpperCase() : "PENDING" %>
          </p>

          <% if(r.status === "accepted" && r.phone && String(r.phone).trim() !== ""){ %>
            <a
              href="https://wa.me/<%= r.phone %>?text=Hello%20we%20matched%20on%20RentSpot%20for%20roommate."
              target="_blank"
              class="book-main-btn"
            >
              Chat on WhatsApp
            </a>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p>No requests yet</p>
    <% } %>

  </div>
</div>

<%- include("partials/footer") %>