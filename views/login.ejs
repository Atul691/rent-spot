<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - RentSpot</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/premium-ui.css">
</head>
<body class="auth-neo-body">

  <div class="auth-neo-shell">
    <div class="auth-neo-bg-shape auth-neo-shape-1"></div>
    <div class="auth-neo-bg-shape auth-neo-shape-2"></div>
    <div class="auth-neo-bg-shape auth-neo-shape-3"></div>

    <div class="auth-neo-card-wrap">

      <div class="auth-neo-showcase">
        <div class="auth-neo-glow"></div>

        <div class="auth-neo-floating auth-neo-panel auth-neo-login-mini">
          <p class="auth-neo-mini-top">RentSpot Stay</p>
          <h3>Welcome back</h3>
          <div class="auth-neo-mini-line">Safe booking </div>
          <div class="auth-neo-mini-line">Premium PG listings</div>
        </div>

        <div class="auth-neo-floating auth-neo-panel auth-neo-info-mini">
          <div class="auth-neo-big-date">Stay</div>
          <p>Find PG rooms, compare options, and book with confidence.</p>
          <div class="auth-neo-dot"></div>
        </div>

        <div class="auth-neo-bottom-card">
          <span>New here?</span>
          <a href="/register">Create account</a>
        </div>
      </div>

      <div class="auth-neo-form-card">
        <div class="auth-neo-form-top">
          <span class="auth-neo-kicker">RentSpot</span>
          <a href="/" class="auth-neo-home-link">Home</a>
        </div>

        <h1>Log in</h1>
        <p class="auth-neo-subtext">Continue to your bookings, offers, and messages.</p>

        <form action="/login" method="POST" class="auth-neo-form">
          <div class="auth-neo-input">
            <span class="auth-neo-input-icon">✉</span>
            <input type="email" name="email" placeholder="Email address" required>
          </div>

          <div class="auth-neo-input">
            <span class="auth-neo-input-icon">🔒</span>
            <input type="password" name="password" placeholder="Password" required>
          </div>

          <button type="submit" class="auth-neo-submit">
            <span>Login</span>
            <span class="auth-neo-arrow">→</span>
          </button>
        </form>

        <div class="auth-neo-footer-text">
          Don’t have an account?
          <a href="/register">Register</a>
        </div>
      </div>

    </div>
  </div>

</body>
</html>