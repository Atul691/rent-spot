<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - RentSpot</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">

  <div class="auth-topbar">
    <div class="auth-brand">RentSpot</div>
    <div class="auth-top-links">
      <a href="/">Home</a>
      <a href="/register">Register</a>
    </div>
  </div>

  <div class="auth-page-wrap">
    <div class="auth-box">

      <div class="auth-welcome purple-panel">
        <div class="welcome-content">
          <h2>Hello, Welcome!</h2>
          <p>Don't have an account?</p>
          <a href="/register" class="welcome-btn">Register</a>
        </div>
      </div>

      <div class="auth-form-side">
        <h1>Login</h1>

        <form action="/login" method="POST" class="auth-form">
          <div class="input-group">
            <input type="email" name="email" placeholder="Email" required>
            <span>👤</span>
          </div>

          <div class="input-group">
            <input type="password" name="password" placeholder="Password" required>
            <span>🔒</span>
          </div>

          <a href="#" class="mini-link">Forgot Password?</a>

          <button type="submit" class="primary-auth-btn">Login</button>
        </form>

        <p class="social-text">or login with social platforms</p>

        <div class="social-icons">
          <div>G</div>
          <div>f</div>
          <div>⌂</div>
          <div>in</div>
        </div>
      </div>

    </div>
  </div>

</body>
</html>