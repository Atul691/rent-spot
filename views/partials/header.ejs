<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RentSpot</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/premium-ui.css">
</head>
<body>

<header class="premium-header">
  <div class="header-container">

    <!-- LOGO -->
    <a href="/" class="logo">
      <span class="logo-icon">R</span>
      <span class="logo-text">RentSpot</span>
    </a>

    <!-- NAV -->
    <nav class="nav-links">

      <a href="/" class="nav-link">Home</a>
      <a href="/about" class="nav-link">About</a>

      <% if(user && user.role === "admin"){ %>
        <a href="/admin" class="nav-link">Dashboard</a>
        <a href="/users" class="nav-link">Users</a>
        <a href="/messages" class="nav-link">Messages</a>
        <a href="/addpg" class="btn-primary">+ Add PG</a>
      <% } %>

      <% if(user){ %>
        <a href="/my-bookings" class="nav-link">Bookings</a>

        <!-- 🔥 NEW BUTTON -->
        <a href="/my-negotiations" class="nav-link">Negotiations</a>

        <a href="/roommate-matches" class="nav-link">Roommates</a>
        <a href="/logout" class="btn-primary">Logout</a>
      <% } else { %>
        <a href="/login" class="nav-link">Login</a>
        <a href="/register" class="btn-primary">Register</a>
      <% } %>

    </nav>

  </div>
</header>