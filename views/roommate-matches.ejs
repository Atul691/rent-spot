<%- include("partials/header") %>

<div class="page-wrap">
  <div class="payment-card roommate-page-card">
    <div class="roommate-top-bar">
      <h2>Roommate Matches</h2>

      <a href="/roommate-profile" class="book-main-btn edit-profile-btn">
        Edit Profile
      </a>
    </div>

    <% if(matches && matches.length > 0){ %>
      <div class="roommate-match-list">

        <% matches.forEach(function(m){ %>
          <div class="roommate-match-card">

            <div class="roommate-card-header">
              <h3><%= m.name %></h3>
              <span class="match-badge"><%= m.match_score %>% Match</span>
            </div>

            <div class="roommate-info-grid">
              <div class="info-chip">
                <span class="info-label">User ID</span>
                <span class="info-value"><%= m.id %></span>
              </div>

              <div class="info-chip">
                <span class="info-label">Email</span>
                <span class="info-value"><%= m.email %></span>
              </div>

              <div class="info-chip">
                <span class="info-label">Budget</span>
                <span class="info-value"><%= m.budget %></span>
              </div>

              <div class="info-chip">
                <span class="info-label">Smoking</span>
                <span class="info-value"><%= m.smoking %></span>
              </div>

              <div class="info-chip">
                <span class="info-label">Sleep Time</span>
                <span class="info-value"><%= m.sleep_time %></span>
              </div>

              <div class="info-chip">
                <span class="info-label">Occupation</span>
                <span class="info-value"><%= m.occupation %></span>
              </div>
            </div>

            <div class="roommate-action-row">
              <% if(m.request_status === "pending"){ %>
                <button type="button" class="roommate-btn pending-btn" disabled>
                  Request Sent
                </button>

              <% } else if(m.request_status === "accepted"){ %>
                <button type="button" class="roommate-btn accepted-btn" disabled>
                  Matched ✓
                </button>

              <% } else { %>
                <form action="/send-roommate-request/<%= m.id %>" method="POST" class="roommate-form-btn">
                  <button type="submit" class="submit-btn roommate-btn send-btn">
                    Send Request
                  </button>
                </form>
              <% } %>

              <% if(m.phone && m.phone.trim() !== ""){ %>
                <a
                  href="https://wa.me/<%= m.phone %>?text=Hello%20I%20found%20your%20profile%20on%20RentSpot%20for%20roommate%20matching."
                  target="_blank"
                  class="book-main-btn roommate-btn whatsapp-btn"
                >
                  Chat on WhatsApp
                </a>
              <% } else { %>
                <span class="no-whatsapp-text">WhatsApp not available</span>
              <% } %>
            </div>

          </div>
        <% }) %>

      </div>
    <% } else { %>
      <p>No roommate matches found yet.</p>
    <% } %>
  </div>
</div>

<%- include("partials/footer") %>