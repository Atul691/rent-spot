<%- include("partials/header") %>

<div class="admin-page">
  <div class="admin-top">
    <div>
      <p class="admin-small">Admin Panel</p>
      <h1>Payment Settings</h1>
      <p class="admin-subtext">Update UPI ID and QR image for payment.</p>
    </div>

    <div class="admin-top-actions">
      <a href="/admin" class="admin-secondary-btn">Back to Dashboard</a>
    </div>
  </div>

  <div class="admin-panel">
    <form action="/payment-settings" method="POST" enctype="multipart/form-data" class="simple-form">

      <div class="form-group">
        <label>Upload QR Image</label>
        <input type="file" name="qr_image">
      </div>

      <% if(setting && setting.qr_image){ %>
        <div class="info-panel" style="max-width:320px;">
          <p style="margin-top:0;font-weight:700;">Current QR</p>
          <img src="<%= setting.qr_image %>" alt="QR Code" style="width:100%;border-radius:18px;">
        </div>
      <% } %>

      <button type="submit" class="admin-primary-btn full-btn">Save Payment Settings</button>
    </form>
  </div>
</div>

<%- include("partials/footer") %>