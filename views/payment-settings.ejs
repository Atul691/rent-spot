<%- include("partials/header") %>

<div class="admin-page">
  <div class="admin-top">
    <div>
      <p class="admin-small">Admin Panel</p>
      <h1>Payment Settings</h1>
      <p class="admin-subtext">Update UPI ID and QR image for payment.</p>
    </div>
    <div class="admin-top-actions">
      <a href="/admin" class="admin-secondary-btn">Back to Dashboard</a>
    </div>
  </div>

  <div class="admin-panel">
    <form action="/payment-settings" method="POST" enctype="multipart/form-data">

  <label>Upload QR Image</label><br>
  <input type="file" name="qr_image" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:14px;"><br><br>

  <% if(setting && setting.qr_image){ %>
    <div style="margin-bottom:16px;">
      <p style="margin-bottom:10px;">Current QR:</p>
      <img src="<%= setting.qr_image %>" alt="QR Code" width="200">
    </div>
  <% } %>

  <button type="submit" class="admin-primary-btn full-btn">Save Payment Settings</button>

</form>
  </div>
</div>

<%- include("partials/footer") %>