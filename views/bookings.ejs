<%- include("partials/header") %>

<div class="admin-page">
  <div class="admin-top">
    <div>
      <p class="admin-small">Admin Panel</p>
      <h1>Bookings</h1>
      <p class="admin-subtext">All booking requests are listed here.</p>
    </div>
    <div class="admin-top-actions">
      <a href="/admin" class="admin-secondary-btn">Back to Dashboard</a>
    </div>
  </div>

  <div class="admin-panel">
    <% if(bookings.length === 0){ %>
      <p class="empty-text">No bookings found.</p>
    <% } else { %>
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>User ID</th>
              <th>PG ID</th>
              <th>Name</th>
              <th>Phone</th>
              <th>Age</th>
              <th>Entry Date</th>
              <th>Notes</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(function(b){ %>
              <tr>
                <td><%= b.id %></td>
                <td><%= b.user_id %></td>
                <td><%= b.pg_id %></td>
                <td><%= b.full_name %></td>
                <td><%= b.phone %></td>
                <td><%= b.age %></td>
                <td><%= b.entry_date %></td>
                <td><%= b.notes %></td>
                <td><%= b.status %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include("partials/footer") %>