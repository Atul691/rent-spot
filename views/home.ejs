<%- include("partials/header") %>

<div class="page-wrap">
  <section class="home-hero">
    <div class="home-hero-content">
      <div>
        <span class="section-kicker">Find Your Perfect Stay</span>
        <h1 class="home-title">Premium PG & Room Booking Experience</h1>
        <p class="home-subtext">
          Discover verified PGs, compare room options, check maps, chat instantly,
          negotiate pricing, and book your stay with a modern RentSpot experience.
        </p>
      </div>

      <form action="/search" method="GET" class="home-search-form">
        <input
          type="text"
          name="q"
          placeholder="Enter Locality / PG Name / Landmark"
          value="<%= typeof q !== 'undefined' ? q : '' %>"
        >
        <button type="submit" class="submit-btn">Search</button>
        <a href="/" class="btn-outline">Reset</a>
      </form>
    </div>
  </section>

  <% if(notes && notes.length > 0){ %>
    <section class="home-notice-wrap">
      <% notes.slice(0,3).forEach(function(note){ %>
        <div class="home-notice-card">
          <div class="home-notice-icon">🔔</div>
          <div>
            <strong>Admin Notice</strong>
            <p><%= note.text %></p>
          </div>
        </div>
      <% }) %>
    </section>
  <% } %>

  <section class="home-list-section">
    <div class="section-head-row">
      <div>
        <span class="section-kicker">Available Listings</span>
        <h2 class="home-section-title">Explore Premium PG Options</h2>
      </div>
      <div class="home-count-badge">
        <%= pg && pg.length ? pg.length : 0 %> Properties
      </div>
    </div>

    <% if(pg && pg.length > 0){ %>
      <div class="home-pg-grid">
        <% pg.forEach(function(item){ %>
          <div class="home-pg-card">
            <div class="home-pg-image-wrap">
              <% if(item.firstImage){ %>
                <img src="<%= item.firstImage %>" alt="<%= item.title %>" class="home-pg-image">
              <% } else { %>
                <img
                  src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1200&q=80"
                  alt="<%= item.title %>"
                  class="home-pg-image"
                >
              <% } %>

              <div class="home-pg-badge">Verified</div>
            </div>

            <div class="home-pg-body">
              <div class="home-pg-top">
                <div class="home-pg-left">
                  <h3 class="home-pg-title"><%= item.title %></h3>
                  <p class="home-pg-location">📍 <%= item.location %></p>

                  <div class="home-pg-badges">
                    <span class="home-mini-badge verified">Verified</span>
                    <span class="home-mini-badge negotiable">Negotiable</span>

                    <% if((item.single_rooms || 0) > 0){ %>
                      <span class="home-mini-badge available">Single Available</span>
                    <% } else if((item.twin_rooms || 0) > 0){ %>
                      <span class="home-mini-badge available">Twin Available</span>
                    <% } else if((item.triple_rooms || 0) > 0){ %>
                      <span class="home-mini-badge available">Triple Available</span>
                    <% } else { %>
                      <span class="home-mini-badge muted">Check Availability</span>
                    <% } %>
                  </div>
                </div>

                <div class="home-pg-price">
                  ₹<%= item.price %><span>/month</span>
                </div>
              </div>

              <p class="home-pg-desc">
                <%= item.description
                  ? item.description.substring(0, 120)
                  : "Comfortable PG with good amenities and booking support." %>...
              </p>

              <div class="home-room-grid">
                <div class="home-room-chip">
                  <span>Single</span>
                  <strong><%= item.single_rooms || 0 %></strong>
                </div>

                <div class="home-room-chip">
                  <span>Twin</span>
                  <strong><%= item.twin_rooms || 0 %></strong>
                </div>

                <div class="home-room-chip">
                  <span>Triple</span>
                  <strong><%= item.triple_rooms || 0 %></strong>
                </div>
              </div>

              <div class="home-card-actions">
                <a href="/pg/<%= item.id %>" class="submit-btn">View Details</a>

                <% if(item.map && item.map.trim() !== ""){ %>
                  <a href="<%= item.map %>" target="_blank" class="btn-outline">View Map</a>
                <% } else { %>
                  <a
                    href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(item.location || '') %>"
                    target="_blank"
                    class="btn-outline"
                  >
                    View Map
                  </a>
                <% } %>

                <% if(user){ %>
                  <a href="/book/<%= item.id %>" class="book-main-btn">Book Now</a>
                <% } else { %>
                  <a href="/login" class="book-main-btn">Login to Book</a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-home-state">
        <h3>No PG listings found</h3>
        <p>Try a different search or add new listings from the admin panel.</p>
      </div>
    <% } %>
  </section>
</div>

<%- include("partials/footer") %>