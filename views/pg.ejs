<%- include("partials/header") %>

<div class="detail-page">
  <div class="detail-card">

    <div class="hero-image-box">
      <% if(images && images.length > 0){ %>
        <img src="<%= images[0].image %>" alt="PG Image" class="hero-image">
        <div class="hero-photo-count">+<%= images.length %> Photos</div>
      <% } else { %>
        <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e" alt="PG Image" class="hero-image">
      <% } %>
    </div>

    <div class="detail-header">
      <h1><%= pg.title %></h1>
      <div class="detail-location">📍 <%= pg.location %></div>
      <div class="overview-price">₹ <%= pg.price %> / month</div>

      <div class="detail-badge-row">
        <span class="detail-badge verified">Verified</span>
        <span class="detail-badge popular">Popular PG</span>
      </div>
    </div>

    <div class="action-icon-row">
      <% if(pg.whatsapp){ %>
        <a href="tel:<%= pg.whatsapp %>" class="icon-action primary">
          <span class="icon-circle">📞</span>
          <span>Call Now</span>
        </a>
      <% } else { %>
        <a href="/pg/<%= pg.id %>" class="icon-action primary">
          <span class="icon-circle">📞</span>
          <span>Call Now</span>
        </a>
      <% } %>

      <% if(pg.whatsapp){ %>
        <a href="https://wa.me/<%= pg.whatsapp %>?text=Hello%20I%20want%20details%20about%20<%= pg.title %>" target="_blank" class="icon-action">
          <span class="icon-circle">💬</span>
          <span>Enquire</span>
        </a>
      <% } else { %>
        <a href="/messages" class="icon-action">
          <span class="icon-circle">💬</span>
          <span>Enquire</span>
        </a>
      <% } %>

      <% if(pg.map){ %>
        <a href="<%= pg.map %>" target="_blank" class="icon-action">
          <span class="icon-circle">📍</span>
          <span>Direction</span>
        </a>
      <% } else { %>
        <a href="/pg/<%= pg.id %>" class="icon-action">
          <span class="icon-circle">📍</span>
          <span>Direction</span>
        </a>
      <% } %>

      <button type="button" class="icon-action" onclick="sharePG()">
        <span class="icon-circle">↗</span>
        <span>Share</span>
      </button>
    </div>

    <% if(pg.whatsapp){ %>
      <a href="https://wa.me/<%= pg.whatsapp %>?text=Hello%20I%20am%20interested%20in%20<%= pg.title %>" target="_blank" class="big-whatsapp-btn">
        WhatsApp
      </a>
    <% } %>

    <div class="overview-section">
      <% if(user){ %>
        <a href="/book/<%= pg.id %>" class="book-main-btn">Book Now</a>
      <% } else { %>
        <a href="/login" class="book-main-btn">Login to Book</a>
      <% } %>
    </div>

    <div class="detail-info-box">
      <h3>Description</h3>
      <p><%= pg.description ? pg.description : "No description added yet." %></p>
    </div>

    <div class="detail-info-box">
      <h3>Facilities</h3>
      <div class="facility-tags">
        <span>🛏️ Bed</span>
        <span>📶 WiFi</span>
        <span>🍽️ Food</span>
        <span>🛁 Bathroom</span>
      </div>
    </div>

    <div class="detail-info-box">
      <h3>Location</h3>
      <% if(pg.map){ %>
        <a href="<%= pg.map %>" target="_blank" class="map-link-btn">Open in Google Maps</a>
      <% } else { %>
        <p>Location map not added yet.</p>
      <% } %>
    </div>

    <div class="detail-info-box">
      <h3>Gallery</h3>
      <div class="gallery-grid">
        <% if(images && images.length > 0){ %>
          <% images.forEach(function(img){ %>
            <a href="<%= img.image %>" target="_blank" class="gallery-item">
              <img src="<%= img.image %>" alt="PG Image">
            </a>
          <% }) %>
        <% } else { %>
          <p>No image uploaded for this PG.</p>
        <% } %>
      </div>
    </div>

    <% if(user){ %>
      <div class="detail-info-box">
        <h3>Send Message to Admin</h3>
        <form action="/message" method="POST" class="rating-form">
          <textarea name="message" placeholder="Write your message to admin" required></textarea>
          <button type="submit" class="submit-btn">Send Message</button>
        </form>
      </div>
    <% } %>

    <div class="detail-info-box">
      <h3>Ratings</h3>

      <% if(user){ %>
        <form action="/rate/<%= pg.id %>" method="POST" class="rating-form">
          <select name="rating" required>
            <option value="">Select Rating</option>
            <option value="1">1 Star</option>
            <option value="2">2 Star</option>
            <option value="3">3 Star</option>
            <option value="4">4 Star</option>
            <option value="5">5 Star</option>
          </select>

          <textarea name="comment" placeholder="Write review"></textarea>
          <button type="submit" class="submit-btn">Submit Rating</button>
        </form>
      <% } %>

      <% if(ratings && ratings.length > 0){ %>
        <div class="rating-list">
          <% ratings.forEach(function(r){ %>
            <div class="rating-box">
              <strong>Rating: <%= r.rating %>/5</strong>
              <p><%= r.comment %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p>No ratings yet.</p>
      <% } %>
    </div>

  </div>
</div>

<script>
function sharePG() {
  const shareData = {
    title: "<%= pg.title %>",
    text: "Check this PG on RentSpot: <%= pg.title %>",
    url: window.location.href
  };

  if (navigator.share) {
    navigator.share(shareData).catch(() => {});
  } else {
    navigator.clipboard.writeText(window.location.href);
    alert("Link copied");
  }
}
</script>

<%- include("partials/footer") %>