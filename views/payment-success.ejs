<%- include("partials/header") %>

<div class="page-wrap">
  <div class="payment-card success-card">

    <div class="success-icon">✅</div>

    <h1>Payment Successful</h1>

    <p class="success-text">
      Your payment has been submitted successfully.
    </p>

    <% if(payment){ %>
      <div class="payment-summary-box">
        <p><strong>Room Price:</strong> ₹<%= payment.room_price %></p>
        <p><strong>Move-In Combo:</strong> <%= payment.combo_name %></p>
        <p><strong>Combo Price:</strong> ₹<%= payment.combo_price %></p>
        <p class="final-total"><strong>Total Paid:</strong> ₹<%= payment.total_amount %></p>
      </div>
    <% } %>

    <p class="success-subtext">
      Please contact admin on WhatsApp and share your payment screenshot for quick confirmation.
    </p>

    <div class="success-action-row">
      <a href="/" class="btn-fill">Go to Home</a>
      <a href="/my-bookings" class="btn-outline">My Bookings</a>
    </div>

  </div>
</div>

<%- include("partials/footer") %>