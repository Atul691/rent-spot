<%- include("partials/header") %>

<div class="page-wrap">
  <div class="payment-card success-card">

    <div class="success-icon">✅</div>

    <h1>Payment Successful</h1>
    <p class="success-text">Your payment has been submitted successfully.</p>

    <% if(payment){ %>
      <div class="payment-summary-box">
        <p>Room Price: ₹<%= payment.room_price %></p>
        <p>Combo: <%= payment.combo_name %></p>
        <p>Total Paid: ₹<%= payment.total_amount %></p>
      </div>
    <% } %>

    <div class="success-action-row">
      <a href="/" class="btn-fill">Home</a>
      <a href="/my-bookings" class="btn-outline">My Bookings</a>
    </div>

  </div>
</div>

<%- include("partials/footer") %>