<%- include("partials/header") %>

<div class="page-wrap">
  <div class="payment-card">
    <h2>Received Requests</h2>

    <% if(requests && requests.length > 0){ %>
      <% requests.forEach(function(r){ %>
        <div class="rating-box">
          <h3><%= r.name %></h3>
          <p><%= r.email %></p>

          <p class="status-badge <%= r.status %>">
            <%= r.status.toUpperCase() %>
          </p>

          <% if(r.status === "pending"){ %>
            <a href="/accept-roommate/<%= r.id %>" class="book-main-btn">Accept</a>
            <a href="/reject-roommate/<%= r.id %>" class="reject-btn">Reject</a>

          <% } else if(r.status === "accepted" && r.phone && r.phone.trim() !== ""){ %>
            <a
              href="https://wa.me/<%= r.phone %>?text=Hello%20we%20matched%20on%20RentSpot%20for%20roommate."
              target